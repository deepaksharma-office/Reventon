<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  data-testid="ui-test-section"

  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
>
  <div
    class="
      spacing-style
      layout-panel-flex
      layout-panel-flex--{{ section.settings.content_direction }}
      section-content-wrapper
      {% if section.settings.vertical_on_mobile %} mobile-column{% endif %}
    "
    style="{% render 'spacing-style', settings: section.settings %}"
    data-testid="section-content"
  >
    <div class="main--wrapper position--{{ section.settings.side }}">
      <div class="content--side_wrapper">
        {% content_for 'blocks' %}
      </div>
      <div class="slide--side_wrapper">
        {% if section.settings.float_left != blank %}
          <div class="image_float_wrap float_left">
            <img
              class="float_img"
              src="{{ section.settings.float_left | image_url }}"
              alt="Floating Image"
              loading="eager"
              width="{{ section.settings.float_left.width }}"
              height="{{ section.settings.float_left.height }}"
            >
          </div>
        {% endif %}
        {% if section.settings.float_middle != blank %}
          <div class="image_float_wrap float_middle">
            <img
              class="float_img"
              src="{{ section.settings.float_middle | image_url }}"
              alt="Floating Image"
              loading="eager"
              width="{{ section.settings.float_middle.width }}"
              height="{{ section.settings.float_middle.height }}"
            >
          </div>
        {% endif %}
        {% if section.settings.float_right != blank %}
          <div class="image_float_wrap float_right">
            <img
              class="float_img"
              src="{{ section.settings.float_right | image_url }}"
              alt="Floating Image"
              loading="eager"
              width="{{ section.settings.float_right.width }}"
              height="{{ section.settings.float_right.height }}"
            >
          </div>
        {% endif %}

        {% assign has_images = false %}
        {% for i in (1..4) %}
          {% capture image_key %}desktop_{{ i }}{% endcapture %}
          {% if section.settings[image_key] %}
            {% assign has_images = true %}
          {% endif %}
        {% endfor %}

        <div
          class="splide {% if has_images == false or section.blocks.size <= 1 %}is-visible{% endif %}"
          {% if has_images and section.blocks.size > 1 %}
            id="splide-{{ section.id }}"
          {% else %}
            id="splide-{{ section.id }}"
          {% endif %}
        >
          <div class="splide__track">
            <ul class="splide__list">
              {% for i in (1..4) %}
                {% capture image_key %}desktop_{{ i }}{% endcapture %}
                {% capture alt_key %}alt_{{ i }}{% endcapture %}
                {% if section.settings[image_key] %}
                  <li class="splide__slide slider__banner-wrap-custom">
                    <div class="banners_images-custom">
                      {{
                        section.settings[image_key]
                        | image_url: width: section.settings[image_key].width
                        | image_tag:
                          class: 'customslider customslider--desktop',
                          alt: section.settings[alt_key],
                          loading: 'eager',
                          width: section.settings[image_key].width,
                          height: section.settings[image_key].height,
                          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000',
                          sizes: '100vw'
                      }}
                    </div>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>

          {% if section.settings.show_pagination %}
            <ul class="splide__pagination splide-pagination-{{ section.id }}"></ul>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

{% render 'splide-slider', section: section %}

{% schema %}
{
  "name": "Custom Slider",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "@theme"
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "float_left",
      "label": "Floating Image Left"
    },
    {
      "type": "image_picker",
      "id": "float_middle",
      "label": "Floating Image Middle"
    },
    {
      "type": "image_picker",
      "id": "float_right",
      "label": "Floating Image Right"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "desktop_1",
      "label": "Slide 1 Image"
    },
    {
      "type": "text",
      "id": "alt_1",
      "label": "Slide 1 Alt Text",
      "default": "Banner Image"
    },
    {
      "type": "image_picker",
      "id": "desktop_2",
      "label": "Slide 2 Image"
    },
    {
      "type": "text",
      "id": "alt_2",
      "label": "Slide 2 Alt Text",
      "default": "Banner Image"
    },
    {
      "type": "image_picker",
      "id": "desktop_3",
      "label": "Slide 3 Image"
    },
    {
      "type": "text",
      "id": "alt_3",
      "label": "Slide 3 Alt Text",
      "default": "Banner Image"
    },
    {
      "type": "image_picker",
      "id": "desktop_4",
      "label": "Slide 4 Image"
    },
    {
      "type": "text",
      "id": "alt_4",
      "label": "Slide 4 Alt Text",
      "default": "Banner Image"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section Width",
      "default": "full-width",
      "options": [
        { "value": "full-width", "label": "Full Width" },
        { "value": "page-width", "label": "Page Width" },
        { "value": "narrow", "label": "Narrow" }
      ]
    },
    {
      "type": "select",
      "id": "content_direction",
      "label": "Content Direction",
      "default": "row",
      "options": [
        { "value": "row", "label": "Row (Horizontal)" },
        { "value": "row-reverse", "label": "Row Reverse" },
        { "value": "column", "label": "Column (Vertical)" },
        { "value": "column-reverse", "label": "Column Reverse" }
      ]
    },
    {
      "type": "checkbox",
      "id": "vertical_on_mobile",
      "label": "Stack vertically on mobile",
      "default": true
    },
    {
      "type": "select",
      "id": "side",
      "label": "Content Position",
      "default": "content-left",
      "options": [
        { "label": "Content Left", "value": "content-left" },
        { "label": "Content Right", "value": "content-right" }
      ]
    },
    {
      "type": "header",
      "content": "Splide Settings"
    },
    {
      "type": "select",
      "id": "slider_type",
      "label": "Slider Type",
      "options": [
        { "value": "slide", "label": "Slide" },
        { "value": "loop", "label": "Loop" },
        { "value": "fade", "label": "Fade" }
      ],
      "default": "loop"
    },
    {
      "type": "range",
      "id": "perPageDesktop",
      "label": "Slides per view (Desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "perPageMobile",
      "label": "Slides per view (Mobile)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "perMove",
      "label": "Slides to move",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap (Desktop)",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Gap (Mobile)",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed (seconds)",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "transition_speed",
      "label": "Transition speed (ms)",
      "min": 300,
      "max": 2000,
      "step": 100,
      "default": 1000
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show pagination",
      "default": false
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Custom Slider"
    }
  ]
}
{% endschema %}
