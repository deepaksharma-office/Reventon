{%- assign custom_slider_id = slider_id | default: section.id -%}
{%- assign custom_section_id = section_id | default: section.id -%}
{%- assign custom_safe_id = custom_slider_id | replace: '-', '_' | replace: '__', '_' -%}

<script>
  (function () {
    if (!window.__splideState) {
      window.__splideState = {};
    }

    var sliderId = "splide-{{ custom_slider_id }}";
    var stateKey = "{{ custom_section_id }}-{{ custom_slider_id }}";

    function initSplide_{{ custom_safe_id }}() {
      if (typeof Splide === 'undefined') {
        setTimeout(initSplide_{{ custom_safe_id }}, 100);
        return;
      }

      var el = document.getElementById(sliderId);
      if (!el) return;

      if (el.splideInstance) {
        el.splideInstance.destroy(true);
      }

      var defaultConfig = {
        type: Shopify.designMode ? 'slide' : '{{ section.settings.slider_type | default: "loop" }}',
        {% if section.settings.slider_type == 'slide' %}
          rewind: true,
        {% endif %}
        perPage: {{ section.settings.perPageDesktop | default: 1 }},
        perMove: {{ section.settings.perMove | default: 1 }},
        autoplay: Shopify.designMode
          ? false
          : {{ section.settings.autoplay | default: false | json }},
        interval: {{ section.settings.autoplay_speed | default: 3 | times: 1000 }},
        speed: {{ section.settings.transition_speed | default: 400 }},
        arrows: {{ section.settings.show_arrows | default: true | json }},
        pagination: {{ section.settings.show_pagination | default: false | json }},
        gap: '{{ section.settings.gap_slide | default: 10 }}px',
        pauseOnHover: {{ section.settings.pause_on_hover | default: false | json }},
        pauseOnFocus: {{ section.settings.pause_on_focus | default: false | json }},
        focus: Shopify.designMode ? false : {{ section.settings.focus | json }},
        breakpoints: {
          768: {
            perPage: {{ section.settings.perPageMobile | default: 1 }},
            gap: '{{ section.settings.gap_mobile | default: 8 }}px'
          },
          480: {
            perPage: {{ section.settings.perPageMobile | default: 1 }},
            gap: '{{ section.settings.gap_mobile | default: 6 }}px'
          }
        }
      };

      {% if config %}
        var config = Object.assign({}, defaultConfig, {{ config | json }});
      {% else %}
        var config = defaultConfig;
      {% endif %}

      var splide = new Splide(el, config);

      splide.on('mounted', function () {
        el.style.visibility = 'visible';
        var savedIndex = window.__splideState[stateKey];
        if (Shopify.designMode && typeof savedIndex === 'number') {
          splide.go(savedIndex);
        }
      });

      splide.on('move', function (newIndex) {
        window.__splideState[stateKey] = newIndex;
      });

      splide.mount();
      el.splideInstance = splide;
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSplide_{{ custom_safe_id }});
    } else {
      initSplide_{{ custom_safe_id }}();
    }

    document.addEventListener('shopify:section:load', function (e) {
      if (e.detail.sectionId === "{{ custom_section_id }}") {
        setTimeout(initSplide_{{ custom_safe_id }}, 100);
      }
    });

    document.addEventListener('shopify:section:unload', function (e) {
      if (e.detail.sectionId === "{{ custom_section_id }}") {
        var el = document.getElementById(sliderId);
        if (el && el.splideInstance) {
          el.splideInstance.destroy(true);
        }
      }
    });

    if (Shopify.designMode) {
      document.addEventListener('shopify:block:select', function (e) {
        var slide = document.querySelector(
          '#' + sliderId + ' [data-block-id="' + e.detail.blockId + '"]'
        );
        if (!slide) return;

        var index = Number(slide.dataset.slideIndex);
        window.__splideState[stateKey] = index;

        var el = document.getElementById(sliderId);
        if (el && el.splideInstance) {
          el.splideInstance.go(index);
        }
      });
    }
  })();
</script>
