{% doc %}
  @prompt
    Create a minimalist testimonial section with a luxury editorial aesthetic on a light warm-gray background (#f5f5f3).
    
    Section layout:
    
    Centered heading at top: “Loved by Our Clients”
    Elegant serif typography for heading (similar to Playfair Display or Cormorant Garamond)
    Large spacing above and below section for a premium feel
    Three testimonial cards in a horizontal row on desktop
    Cards should stack vertically on mobile
    Each card should have:
    Thin light-gray border
    White background
    Generous padding
    Center aligned content
    Equal height cards
    Subtle hover effect
    
    Inside each testimonial card:
    
    5 gold stars at top
    Italic testimonial text in soft gray color
    Customer name at bottom in bold black text
    Plenty of spacing between stars, text, and name
    
    Content examples:
    
    Card 1:
    ★★★★★
    “Absolutely stunning decorations for my daughter's birthday. The team was professional and the setup was flawless.”
    — Sarah M.
    
    Card 2:
    ★★★★★
    “The Ramadan package transformed our home. Premium quality items and excellent customer service.”
    — Ahmed K.
    
    Card 3:
    ★★★★★
    “Used Festiva for my engagement party. The floral arrangements and backdrops were breathtaking. Highly recommend!”
    — Fatima R.
    
    Design style:
    
    Minimal
    Luxury
    Elegant
    Editorial-inspired
    Soft neutral palette
    Spacious layout
    Mobile responsive
    
    Customization settings:
    
    Editable heading text
    Editable testimonial text
    Editable customer names
    Editable star icons
    Adjustable spacing and colors
    Add/remove testimonial blocks dynamically
    
    Mobile responsiveness:
    
    1 card per row on mobile
    Proper padding on smaller screens
    Maintain centered alignment and readability
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonials-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    width: 100%;
  }

  .ai-testimonials-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-testimonials-heading-{{ ai_gen_id }} {
    font-family: 'Playfair Display', serif;
    font-size: {{ block.settings.heading_size }}px;
    text-align: center;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-weight: 400;
    letter-spacing: 0.5px;
  }

  .ai-testimonials-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_gap }}px;
    margin: 0;
  }

  .ai-testimonial-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    min-height: 280px;
  }

  .ai-testimonial-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
  }

  .ai-testimonial-stars-{{ ai_gen_id }} {
    color: {{ block.settings.star_color }};
    font-size: {{ block.settings.star_size }}px;
    margin-bottom: {{ block.settings.stars_spacing }}px;
    letter-spacing: 2px;
  }

  .ai-testimonial-text-{{ ai_gen_id }} {
    font-style: italic;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: 0 0 {{ block.settings.text_spacing }}px;
    flex-grow: 1;
  }

  .ai-testimonial-name-{{ ai_gen_id }} {
    font-weight: 700;
    color: {{ block.settings.name_color }};
    font-size: {{ block.settings.name_size }}px;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-testimonials-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_gap_mobile }}px;
    }

    .ai-testimonials-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px 16px {{ block.settings.section_padding_bottom_mobile }}px;
    }

    .ai-testimonials-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      margin-bottom: {{ block.settings.heading_spacing_mobile }}px;
    }

    .ai-testimonial-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-testimonials-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-testimonials-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-testimonials-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-testimonials-grid-{{ ai_gen_id }}">
      {% if block.settings.show_card_1 %}
        <div class="ai-testimonial-card-{{ ai_gen_id }}">
          <div class="ai-testimonial-stars-{{ ai_gen_id }}">{{ block.settings.stars_1 }}</div>
          <p class="ai-testimonial-text-{{ ai_gen_id }}">{{ block.settings.testimonial_1 }}</p>
          <p class="ai-testimonial-name-{{ ai_gen_id }}">{{ block.settings.name_1 }}</p>
        </div>
      {% endif %}

      {% if block.settings.show_card_2 %}
        <div class="ai-testimonial-card-{{ ai_gen_id }}">
          <div class="ai-testimonial-stars-{{ ai_gen_id }}">{{ block.settings.stars_2 }}</div>
          <p class="ai-testimonial-text-{{ ai_gen_id }}">{{ block.settings.testimonial_2 }}</p>
          <p class="ai-testimonial-name-{{ ai_gen_id }}">{{ block.settings.name_2 }}</p>
        </div>
      {% endif %}

      {% if block.settings.show_card_3 %}
        <div class="ai-testimonial-card-{{ ai_gen_id }}">
          <div class="ai-testimonial-stars-{{ ai_gen_id }}">{{ block.settings.stars_3 }}</div>
          <p class="ai-testimonial-text-{{ ai_gen_id }}">{{ block.settings.testimonial_3 }}</p>
          <p class="ai-testimonial-name-{{ ai_gen_id }}">{{ block.settings.name_3 }}</p>
        </div>
      {% endif %}
    </div>
  </div>
</div>

