{% doc %}
  @prompt
    Create a premium “Event Packages” collection section with a clean luxury editorial layout exactly like the reference design.
    
    Section Requirements:
    
    3-column card grid on desktop
    1-column stacked layout on mobile
    Equal card heights
    Soft light beige/off-white background (#F7F5F2)
    Large rounded corners (24px)
    Spacious luxury padding and white space
    Minimal elegant aesthetic
    Smooth hover animation with slight image zoom
    
    Card Design:
    
    Each card should contain:
    
    Top image with rounded corners
    Package title in elegant serif typography
    Short description text underneath
    Thin divider line
    “Starting from” small muted label
    Price in bold large typography with “SR”
    
    Typography:
    
    Heading font style: elegant serif similar to Playfair Display or Cormorant
    Body text: clean modern sans-serif
    Title color: #1F1F1F
    Description color: #6F6F6F
    Price color: #111111
    
    Spacing:
    
    Card padding: 24px
    Gap between cards: 28px
    Image aspect ratio: portrait landscape hybrid similar to luxury editorial cards
    Rounded image corners: 18px
    
    Hover Effects:
    
    Card slightly lifts upward
    Image zooms subtly
    Smooth transition duration 0.3s
    
    Content Structure Example:
    
    Card 1:
    Title: Birthday Deluxe
    Description: Complete setup including balloon arches, custom backdrop, and table decor.
    Price: 499.00 SR
    
    Card 2:
    Title: Wedding Elegance
    Description: Premium floral arrangements, elegant lighting, and bespoke centerpieces.
    Price: 1499.00 SR
    
    Card 3:
    Title: Eid Celebration
    Description: Festive setup with traditional elements, lanterns, and elegant tableware.
    Price: 2299.00 SR
    
    Additional Settings:
    
    Allow editable image upload for each card
    Allow editable title, description, and pricing
    Mobile responsive
    Keep cards centered with max-width container
    Use subtle shadow only if necessary
    Maintain exact luxury minimal style from the reference image
    No gradients
    No bold background colors
    Editorial premium Shopify storefront aesthetic
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-event-packages-{{ ai_gen_id }} {
    width: 100%;
    display: block;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-event-packages-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .ai-event-packages-heading-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.heading_margin_bottom }}px;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    line-height: 1.2;
  }

  .ai-event-packages-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-event-packages-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    {% if block.settings.card_shadow %}
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    {% endif %}
  }

  .ai-event-packages-card-{{ ai_gen_id }}:hover {
    transform: translateY(-8px);
    {% if block.settings.card_shadow %}
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    {% endif %}
  }

  .ai-event-packages-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: {{ block.settings.image_margin_bottom }}px;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
  }

  .ai-event-packages-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-event-packages-card-{{ ai_gen_id }}:hover .ai-event-packages-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-event-packages-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-event-packages-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-event-packages-card-content-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-event-packages-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_margin_bottom }}px;
    line-height: 1.3;
  }

  .ai-event-packages-description-{{ ai_gen_id }} {
    font-family: {{ block.settings.description_font.family }}, {{ block.settings.description_font.fallback_families }};
    font-weight: {{ block.settings.description_font.weight }};
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0 0 {{ block.settings.description_margin_bottom }}px;
    flex-grow: 1;
  }

  .ai-event-packages-divider-{{ ai_gen_id }} {
    width: 100%;
    height: 1px;
    background-color: {{ block.settings.divider_color }};
    margin: {{ block.settings.divider_margin }}px 0;
  }

  .ai-event-packages-price-section-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-event-packages-price-label-{{ ai_gen_id }} {
    font-family: {{ block.settings.description_font.family }}, {{ block.settings.description_font.fallback_families }};
    font-size: {{ block.settings.price_label_size }}px;
    color: {{ block.settings.description_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-event-packages-price-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.price_font_weight }};
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    line-height: 1.2;
  }

  @media screen and (max-width: 989px) {
    .ai-event-packages-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.card_gap_mobile }}px;
    }

    .ai-event-packages-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-event-packages-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-event-packages-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-event-packages-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_gap_mobile }}px;
    }

    .ai-event-packages-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px 16px {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }
  }
{% endstyle %}

<event-packages-{{ ai_gen_id }} class="ai-event-packages-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-event-packages-container-{{ ai_gen_id }}">
    {% if block.settings.section_heading != blank %}
      <h2 class="ai-event-packages-heading-{{ ai_gen_id }}">{{ block.settings.section_heading }}</h2>
    {% endif %}

    <div class="ai-event-packages-grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign card_image_key = 'card_' | append: i | append: '_image'
          assign card_title_key = 'card_' | append: i | append: '_title'
          assign card_description_key = 'card_' | append: i | append: '_description'
          assign card_price_key = 'card_' | append: i | append: '_price'

          assign card_image = block.settings[card_image_key]
          assign card_title = block.settings[card_title_key]
          assign card_description = block.settings[card_description_key]
          assign card_price = block.settings[card_price_key]
        %}

        <div class="ai-event-packages-card-{{ ai_gen_id }}">
          <div class="ai-event-packages-image-wrapper-{{ ai_gen_id }}">
            {% if card_image %}
              <img
                src="{{ card_image | image_url: width: 800 }}"
                alt="{{ card_image.alt | escape }}"
                loading="lazy"
                width="{{ card_image.width }}"
                height="{{ card_image.height }}"
                class="ai-event-packages-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-event-packages-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-event-packages-card-content-{{ ai_gen_id }}">
            {% if card_title != blank %}
              <h3 class="ai-event-packages-title-{{ ai_gen_id }}">{{ card_title }}</h3>
            {% endif %}

            {% if card_description != blank %}
              <p class="ai-event-packages-description-{{ ai_gen_id }}">{{ card_description }}</p>
            {% endif %}

            <div class="ai-event-packages-divider-{{ ai_gen_id }}"></div>

            <div class="ai-event-packages-price-section-{{ ai_gen_id }}">
              <span class="ai-event-packages-price-label-{{ ai_gen_id }}">{{ block.settings.price_label }}</span>
              {% if card_price != blank %}
                <span class="ai-event-packages-price-{{ ai_gen_id }}">{{ card_price }} {{ block.settings.currency_symbol }}</span>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</event-packages-{{ ai_gen_id }}>

<script>
  (function() {
    class EventPackages{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('event-packages-{{ ai_gen_id }}', EventPackages{{ ai_gen_id }});
  })();
</script>

